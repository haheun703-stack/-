{
  "tab_name": "급락반등 포착기",
  "tab_id": "crash-bounce",
  "description": "극도로 빠진 종목 중 큰손(기관/외국인)이 매수하기 시작한 종목. 백테스트 검증 완료 (승률 60%+, 5일 수익 +3.3%)",
  "supabase_table": "dashboard_crash_bounce",
  "api_endpoint": "/api/crash-bounce",
  "query": "SELECT * FROM dashboard_crash_bounce WHERE date = (SELECT MAX(date) FROM dashboard_crash_bounce) ORDER BY score DESC LIMIT 50",
  "update_frequency": "매일 장마감 후 1회 (BAT-D G3.9)",
  "data_source": "퀀트봇 scan_crash_bounce.py → crash_bounce_scan.json → FLOWX 업로드",

  "ddl": "CREATE TABLE IF NOT EXISTS dashboard_crash_bounce (\n  date TEXT NOT NULL,\n  ticker TEXT NOT NULL,\n  name TEXT,\n  close FLOAT DEFAULT 0,\n  change_pct FLOAT DEFAULT 0,\n  gap_20ma FLOAT DEFAULT 0,\n  bb_position FLOAT DEFAULT 0,\n  volume_ratio FLOAT DEFAULT 0,\n  foreign_net FLOAT DEFAULT 0,\n  inst_net FLOAT DEFAULT 0,\n  foreign_days INT DEFAULT 0,\n  inst_days INT DEFAULT 0,\n  signal_type TEXT,\n  grade TEXT,\n  score INT DEFAULT 0,\n  reasons TEXT,\n  PRIMARY KEY (date, ticker)\n);\n\nALTER TABLE dashboard_crash_bounce ENABLE ROW LEVEL SECURITY;\nCREATE POLICY \"anon_read_crash_bounce\" ON dashboard_crash_bounce\n  FOR SELECT TO anon USING (true);",

  "columns": {
    "date": "날짜 (YYYY-MM-DD)",
    "ticker": "종목코드 (6자리)",
    "name": "종목명",
    "close": "현재가 (원)",
    "change_pct": "전일대비 등락률 (%)",
    "gap_20ma": "20일 이동평균 이격도 (%, 음수=급락)",
    "bb_position": "볼린저밴드 위치 (0~1, 0=하단 1=상단, 음수=하단이탈)",
    "volume_ratio": "거래량 배수 (20일 평균 대비, 3.0=3배)",
    "foreign_net": "외국인 당일 순매수 (억원)",
    "inst_net": "기관 당일 순매수 (억원)",
    "foreign_days": "외국인 연속 매수 일수",
    "inst_days": "기관 연속 매수 일수",
    "signal_type": "시그널 유형 (아래 참조)",
    "grade": "등급 (아래 참조)",
    "score": "종합 점수 (0~100)",
    "reasons": "포착 이유 (JSON 배열 문자열)"
  },

  "signal_types": [
    {"value": "복합급락 반등", "label": "복합급락 반등", "description": "볼린저급락 + 거래량폭발 동시 충족 (최강)", "color": "#FF0000", "badge": "BEST"},
    {"value": "볼린저급락 반등", "label": "볼린저급락 반등", "description": "20일평균 -15% + 볼린저밴드 하단 이탈 + 큰손 매수", "color": "#FF6600"},
    {"value": "거래량폭발 반등", "label": "거래량폭발 반등", "description": "20일평균 -15% + 거래량 3배+ + 큰손 매수", "color": "#FF9900"},
    {"value": "관심", "label": "관심", "description": "조건 근접 (이격도 -12%~-15%)", "color": "#999999"}
  ],

  "grades": [
    {"value": "적극매수", "label": "적극매수", "icon": "★", "color": "#FF0000", "bg": "#FFF0F0", "description": "두 시그널 동시 또는 쌍끌이(기관+외인) 수급"},
    {"value": "매수", "label": "매수", "icon": "◎", "color": "#FF6600", "bg": "#FFF5E6", "description": "단일 시그널 + 기관 또는 외인 순매수"},
    {"value": "관심", "label": "관심", "icon": "○", "color": "#999999", "bg": "#F5F5F5", "description": "조건 근접 — 추가 하락 시 매수 진입 대기"}
  ],

  "backtest_stats": {
    "볼린저급락 반등": {
      "period": "2019~2026 (7년)",
      "samples": 1034,
      "avg_return_d5": "+3.38%",
      "win_rate": "60.2%",
